{
    "name": "image-generation-agent",
    "version": "1.0.0",
    "description": "图像生成Agent - 基于Mastra和Google Gemini 2.5 Flash Image",
    "main": "dist/index.js",
    "type": "module",
    "scripts": {
        "dev": "mastra dev",
        "build": "tsc && wrangler deploy --dry-run",
        "deploy": "wrangler deploy",
        "deploy:r2": "wrangler r2 bucket create image-agent-storage",
        "deploy:secrets": "echo '请运行: wrangler secret put MOONSHOT_API_KEY && wrangler secret put GOOGLE_API_KEY'",
        "test:api": "node test/api-test.js",
        "logs": "wrangler tail"
    },
    "keywords": [
        "ai",
        "agent",
        "image-generation",
        "mastra",
        "moonshot",
        "kimi",
        "cloudflare",
        "google-imagen"
    ],
    "author": "",
    "license": "MIT",
    "dependencies": {
        "@google/genai": "^0.5.0",
        "@mastra/core": "^0.20.0",
        "hono": "^4.0.0",
        "zod": "^3"
    },
    "devDependencies": {
        "@cloudflare/workers-types": "^4.20241127.0",
        "@types/node": "^24.6.2",
        "mastra": "^0.14.1",
        "tsx": "^4.20.6",
        "typescript": "^5.9.3",
        "wrangler": "^3.80.0"
    },
    "engines": {
        "node": ">=18.0.0",
        "npm": ">=9.0.0"
    }
}
