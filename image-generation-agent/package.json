{
  "name": "image-generation-agent",
  "version": "1.0.0",
  "main": "index.js",
  "description": "图像生成Agent - 基于Mastra和Google Gemini",
  "scripts": {
    "start": "mastra start",
    "dev": "mastra dev",
    "build": "tsc && wrangler deploy --dry-run",
    "deploy": "wrangler deploy",
    "deploy:r2": "wrangler r2 bucket create image-agent-storage",
    "deploy:secrets": "echo '请运行: wrangler secret put GOOGLE_API_KEY'",
    "test:api": "node test/api-test.js",
    "test:image": "node test-image-generation.js",
    "logs": "wrangler tail",
    "clean": "rm -rf output/*.png"
  },
  "keywords": [
    "gemini",
    "image-generation",
    "ai",
    "mastra"
  ],
  "author": "",
  "license": "ISC",
  "type": "module",
  "engines": {
    "node": ">=20.9.0"
  },
  "dependencies": {
    "@ai-sdk/google": "^2.0.17",
    "@ai-sdk/openai": "^2.0.42",
    "@aws-sdk/client-s3": "^3.906.0",
    "@cloudflare/workers-types": "^4.20251004.0",
    "@google/genai": "^1.22.0",
    "@mastra/core": "^0.20.0",
    "@mastra/deployer-cloudflare": "^0.14.5",
    "@mastra/libsql": "^0.15.1",
    "@mastra/loggers": "^0.10.15",
    "@mastra/memory": "^0.15.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.6.2",
    "mastra": "^0.14.1",
    "typescript": "^5.9.3"
  }
}
